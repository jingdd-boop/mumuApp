.tabs {
  display: flex;
  gap: 8rpx;
  margin-bottom: 24rpx;
  padding: 6rpx;
  border-radius: 999rpx;
  background: linear-gradient(145deg, #e8e2f2, #ded8ea);
  box-shadow: var(--shadow-inset);
}

.tab {
  flex: 1;
  text-align: center;
  padding: 18rpx 0;
  font-size: 26rpx;
  color: var(--color-text-tertiary);
  border-radius: 999rpx;
  font-weight: 500;
}

.tab.active {
  color: var(--color-text);
  font-weight: 700;
  background: linear-gradient(145deg, #ffffff, #f8f4ff);
  box-shadow: var(--shadow-clay-sm);
}

.add-section {
  margin-bottom: 24rpx;
}

.add-section-head {
  margin-bottom: 16rpx;
}

.add-section-title {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--color-accent);
  letter-spacing: 2rpx;
}

.add-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
}

.add-chip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  padding: 20rpx 8rpx;
  background: linear-gradient(145deg, #ffffff, #f8f4ff);
  border: 2rpx solid rgba(255, 255, 255, 0.8);
  border-radius: 24rpx;
  box-shadow: var(--shadow-clay-sm);
}

.add-chip:active {
  box-shadow: var(--shadow-inset);
  transform: scale(0.98);
}

.add-chip-icon {
  font-size: 36rpx;
  line-height: 1;
}

.add-chip-label {
  font-size: 24rpx;
  font-weight: 600;
  color: var(--color-text);
}

.records-section-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.records-section-title {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--color-accent);
  letter-spacing: 2rpx;
}

.records-section-count {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

.compact-empty {
  padding: 24rpx 0;
}

.record-list {
  background: linear-gradient(145deg, #faf8ff, #f3eef9);
  border-radius: var(--radius-card);
  overflow: hidden;
  box-shadow: var(--shadow-clay);
  border: 2rpx solid rgba(255, 255, 255, 0.65);
  padding: 8rpx;
}

.record-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 24rpx;
  margin-bottom: 8rpx;
  background: linear-gradient(145deg, #ffffff, #f8f4ff);
  border-radius: 28rpx;
  box-shadow: var(--shadow-clay-sm);
  border: 2rpx solid rgba(255, 255, 255, 0.8);
}

.record-item:last-child {
  margin-bottom: 0;
}

.record-main {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
}

.record-icon {
  font-size: 32rpx;
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(145deg, #f0ebf8, #e4ddf0);
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: var(--shadow-inset);
}

.record-info {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
}

.record-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
}

.record-detail {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  line-height: 1.4;
}

.record-delete {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: linear-gradient(145deg, #f0ebf8, #e8e2f2);
  box-shadow: var(--shadow-inset);
  flex-shrink: 0;
}

.record-delete:active {
  color: var(--color-accent);
}

.module-card {
  background: linear-gradient(145deg, #faf8ff, #f3eef9);
  border-radius: var(--radius-card);
  padding: 28rpx;
  box-shadow: var(--shadow-clay);
  border: 2rpx solid rgba(255, 255, 255, 0.65);
}

.module-header {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 24rpx;
}

.module-header.compact {
  margin-bottom: 20rpx;
}

.module-icon {
  font-size: 32rpx;
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(135deg, #8b6fe8, #7b5cf0);
  border-radius: 22rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 10rpx 24rpx rgba(123, 92, 240, 0.32);
}

.module-title-wrap {
  flex: 1;
}

.module-title {
  display: block;
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text);
}

.module-sub {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  margin-top: 4rpx;
}

.chart-section {
  margin-bottom: 28rpx;
  padding: 20rpx;
  background: linear-gradient(145deg, #ffffff, #f8f4ff);
  border-radius: 28rpx;
  box-shadow: var(--shadow-inset);
}

.chart-section.compact {
  margin-bottom: 24rpx;
}

.chart-title,
.daily-title {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--color-accent);
  letter-spacing: 2rpx;
  margin-bottom: 16rpx;
}

.chart-scroll {
  width: 100%;
  white-space: nowrap;
}

.chart-cols {
  display: inline-flex;
  gap: 10rpx;
  padding: 4rpx 0 12rpx;
  min-height: 200rpx;
}

.chart-col {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 72rpx;
  flex-shrink: 0;
}

.chart-col-bars {
  display: flex;
  align-items: flex-end;
  gap: 4rpx;
  height: 140rpx;
  margin-bottom: 12rpx;
}

.chart-bar-wrap {
  width: 16rpx;
  height: 140rpx;
  background: linear-gradient(180deg, #e8e2f2, #ded8ea);
  border-radius: 10rpx;
  display: flex;
  align-items: flex-end;
  overflow: hidden;
  box-shadow: var(--shadow-inset);
}

.chart-mood-wrap {
  align-items: center;
  justify-content: center;
}

.chart-mood-emoji {
  font-size: 22rpx;
  line-height: 1;
}

.chart-bar {
  width: 100%;
  border-radius: 8rpx 8rpx 4rpx 4rpx;
  min-height: 0;
}

.bar-lochia { background: linear-gradient(180deg, #e8a0c0, #d480a8); }
.bar-pain { background: linear-gradient(180deg, #ffb86a, #ff9f5a); }
.bar-weight { background: linear-gradient(180deg, #8ec5e8, #6b9fd4); }
.bar-breast { background: linear-gradient(180deg, #f0b8d0, #e8a0c0); }

.chart-day-num {
  font-size: 18rpx;
  color: var(--color-text-secondary);
  font-weight: 600;
}

.chart-day-date {
  font-size: 16rpx;
  color: var(--color-text-tertiary);
  margin-top: 4rpx;
}

.chart-legend {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
  padding-top: 12rpx;
}

.chart-legend.compact .legend-item {
  font-size: 20rpx;
  padding: 6rpx 12rpx;
}

.legend-item {
  display: flex;
  align-items: center;
  gap: 10rpx;
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  background: linear-gradient(145deg, #f5f1fb, #ebe6f4);
  box-shadow: var(--shadow-clay-sm);
}

.legend-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 4rpx;
}

.daily-card {
  background: linear-gradient(145deg, #ffffff, #f8f4ff);
  border: 2rpx solid rgba(255, 255, 255, 0.8);
  border-radius: 24rpx;
  padding: 20rpx 24rpx;
  margin-bottom: 10rpx;
  box-shadow: var(--shadow-clay-sm);
}

.daily-card.compact .daily-card-head {
  margin-bottom: 16rpx;
}

.daily-card-empty {
  opacity: 0.55;
}

.daily-card-head {
  display: flex;
  justify-content: space-between;
  align-items: baseline;
  margin-bottom: 20rpx;
}

.daily-day {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text);
}

.daily-date {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

.metric-row {
  display: flex;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 14rpx;
}

.metric-row.compact {
  margin-bottom: 12rpx;
}

.metric-row:last-child {
  margin-bottom: 0;
}

.metric-icon {
  font-size: 24rpx;
  width: 44rpx;
  height: 44rpx;
  background: linear-gradient(145deg, #f0ebf8, #e4ddf0);
  border-radius: 12rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: var(--shadow-inset);
}

.metric-body {
  flex: 1;
  min-width: 0;
}

.metric-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 12rpx;
  margin-bottom: 8rpx;
}

.metric-label {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
}

.metric-value {
  font-size: 22rpx;
  color: var(--color-text);
  text-align: right;
  flex: 1;
  line-height: 1.35;
}

.metric-bar-bg {
  height: 6rpx;
  background: linear-gradient(90deg, #e8e2f2, #ded8ea);
  border-radius: 999rpx;
  overflow: hidden;
  box-shadow: var(--shadow-inset);
}

.metric-bar-fill {
  height: 100%;
  border-radius: 999rpx;
  min-width: 0;
}
