<page-header title="记录" subtitle="{{pageSubtitle}}" />
<view class="container">
  <view class="tabs">
    <view class="tab {{viewTab === 'record' ? 'active' : ''}}" bindtap="switchView" data-tab="record">今日记录</view>
    <view class="tab {{viewTab === 'trend' ? 'active' : ''}}" bindtap="switchView" data-tab="trend">数据趋势</view>
  </view>

  <!-- 今日记录 -->
  <block wx:if="{{viewTab === 'record'}}">
    <view class="add-section">
      <view class="add-section-head">
        <text class="add-section-title">添加记录</text>
      </view>
      <view class="add-grid">
        <view
          class="add-chip"
          wx:for="{{addTypes}}"
          wx:key="type"
          bindtap="onAdd"
          data-type="{{item.type}}"
        >
          <text class="add-chip-icon">{{item.icon}}</text>
          <text class="add-chip-label">{{item.label}}</text>
        </view>
      </view>
    </view>

    <view class="records-section">
      <view class="records-section-head">
        <text class="records-section-title">今日记录</text>
        <text class="records-section-count" wx:if="{{records.length > 0}}">{{records.length}} 条</text>
      </view>
      <view wx:if="{{records.length === 0}}" class="empty-tip compact-empty">今天还没有记录</view>
      <view class="record-list" wx:else>
        <view class="record-item" wx:for="{{records}}" wx:key="id">
          <view class="record-main">
            <view class="record-icon">{{item.icon}}</view>
            <view class="record-info">
              <text class="record-title">{{item.title}} · {{item.time}}</text>
              <text class="record-detail">{{item.detail}}</text>
            </view>
          </view>
          <view class="record-delete" bindtap="onDelete" data-id="{{item.id}}">删除</view>
        </view>
      </view>
    </view>
  </block>

  <!-- 数据趋势 -->
  <block wx:if="{{viewTab === 'trend'}}">
    <view class="module-card">
      <view class="module-header compact">
        <view class="module-icon small">🌸</view>
        <view class="module-title-wrap">
          <text class="module-title">身体恢复趋势</text>
          <text class="module-sub">左右滑动查看各天数据</text>
        </view>
      </view>

      <view wx:if="{{!hasTrendData}}" class="empty-tip">还没有记录，切换到「今日记录」添加吧</view>

      <block wx:else>
        <view class="chart-section compact">
          <view class="chart-title">OVERVIEW</view>
          <scroll-view class="chart-scroll" scroll-x enable-flex>
            <view class="chart-cols">
              <view class="chart-col" wx:for="{{chartDays}}" wx:key="date">
                <view class="chart-col-bars chart-col-bars-mom">
                  <view class="chart-bar-wrap">
                    <view class="chart-bar bar-lochia" style="height: {{item.lochiaBar}}%"></view>
                  </view>
                  <view class="chart-bar-wrap">
                    <view class="chart-bar bar-pain" style="height: {{item.painBar}}%"></view>
                  </view>
                  <view class="chart-bar-wrap chart-mood-wrap">
                    <text class="chart-mood-emoji">{{item.moodEmoji}}</text>
                  </view>
                  <view class="chart-bar-wrap">
                    <view class="chart-bar bar-weight" style="height: {{item.weightBar}}%"></view>
                  </view>
                  <view class="chart-bar-wrap">
                    <view class="chart-bar bar-breast" style="height: {{item.breastBar}}%"></view>
                  </view>
                </view>
                <text class="chart-day-num">第{{item.dayIndex}}天</text>
                <text class="chart-day-date">{{item.dateShort}}</text>
              </view>
            </view>
          </scroll-view>
          <view class="chart-legend compact">
            <view class="legend-item"><view class="legend-dot bar-lochia"></view><text>恶露</text></view>
            <view class="legend-item"><view class="legend-dot bar-pain"></view><text>疼痛</text></view>
            <view class="legend-item"><text>💭 情绪</text></view>
            <view class="legend-item"><view class="legend-dot bar-weight"></view><text>体重</text></view>
            <view class="legend-item"><view class="legend-dot bar-breast"></view><text>乳房</text></view>
          </view>
        </view>

        <view class="daily-section">
          <view class="daily-title">DAILY DETAIL</view>
          <view class="daily-card compact {{item.hasData ? '' : 'daily-card-empty'}}" wx:for="{{detailDays}}" wx:key="date">
            <view class="daily-card-head">
              <text class="daily-day">{{item.dayLabel}}</text>
              <text class="daily-date">{{item.dateShort}}</text>
            </view>
            <view class="metric-row compact" wx:for="{{item.metrics}}" wx:for-item="metric" wx:key="label">
              <view class="metric-icon small">{{metric.isMood ? metric.emoji : metric.icon}}</view>
              <view class="metric-body">
                <view class="metric-top">
                  <text class="metric-label">{{metric.label}}</text>
                  <text class="metric-value">{{metric.value}}</text>
                </view>
                <view class="metric-bar-bg" wx:if="{{!metric.isMood && metric.barPercent > 0}}">
                  <view class="metric-bar-fill" style="width: {{metric.barPercent}}%; background: {{metric.color}}"></view>
                </view>
              </view>
            </view>
          </view>
        </view>
      </block>
    </view>
  </block>
</view>
