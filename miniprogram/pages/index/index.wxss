.hero-card {
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, #8b6fe8 0%, #7b5cf0 50%, #6b4fd4 100%);
  border-radius: 40rpx;
  padding: 32rpx 32rpx 28rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-clay-lg);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.hero-deco {
  position: absolute;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
}

.hero-deco-1 {
  width: 160rpx;
  height: 160rpx;
  top: -40rpx;
  right: -20rpx;
}

.hero-deco-2 {
  width: 100rpx;
  height: 100rpx;
  bottom: 20rpx;
  right: 80rpx;
  background: rgba(255, 200, 150, 0.25);
}

.hero-deco-3 {
  width: 60rpx;
  height: 60rpx;
  top: 60rpx;
  right: 120rpx;
  background: rgba(255, 255, 255, 0.18);
}

.hero-label {
  display: block;
  font-size: 24rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.75);
  letter-spacing: 2rpx;
  margin-bottom: 16rpx;
  position: relative;
  z-index: 1;
}

.hero-day-row {
  display: flex;
  align-items: baseline;
  gap: 8rpx;
  margin-bottom: 12rpx;
  position: relative;
  z-index: 1;
}

.day-num {
  font-size: 88rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1;
  letter-spacing: -4rpx;
  text-shadow: 0 8rpx 24rpx rgba(0, 0, 0, 0.15);
}

.day-total {
  font-size: 28rpx;
  font-weight: 500;
  color: rgba(255, 255, 255, 0.8);
}

.stage-tag {
  display: inline-block;
  font-size: 22rpx;
  font-weight: 600;
  color: #7b5cf0;
  background: rgba(255, 255, 255, 0.92);
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  margin-bottom: 24rpx;
  position: relative;
  z-index: 1;
  box-shadow: 0 6rpx 16rpx rgba(0, 0, 0, 0.1);
}

.progress-wrap {
  display: flex;
  align-items: center;
  gap: 20rpx;
  position: relative;
  z-index: 1;
}

.progress-bar {
  flex: 1;
  height: 12rpx;
  background: rgba(255, 255, 255, 0.25);
  border-radius: 999rpx;
  overflow: hidden;
  box-shadow: inset 0 2rpx 6rpx rgba(0, 0, 0, 0.1);
}

.progress-fill {
  height: 100%;
  background: linear-gradient(90deg, #ffb86a, #ff9f5a);
  border-radius: 999rpx;
  box-shadow: 0 2rpx 8rpx rgba(255, 159, 90, 0.5);
}

.progress-text {
  font-size: 26rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.9);
  white-space: nowrap;
}

.hero-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
  padding: 18rpx 22rpx;
  background: rgba(255, 255, 255, 0.18);
  border-radius: 24rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.25);
  position: relative;
  z-index: 1;
}

.hero-entry:active {
  background: rgba(255, 255, 255, 0.28);
}

.hero-entry-left {
  display: flex;
  align-items: center;
  gap: 20rpx;
  flex: 1;
  min-width: 0;
}

.hero-entry-icon {
  font-size: 34rpx;
  flex-shrink: 0;
}

.hero-entry-text {
  display: flex;
  flex-direction: column;
  gap: 4rpx;
}

.hero-entry-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #fff;
}

.hero-entry-sub {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.75);
}

.hero-entry-arrow {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ffb86a, #ff9f5a);
  color: #fff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 8rpx 20rpx rgba(255, 159, 90, 0.4);
}

.ended-tip {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.85);
  line-height: 1.5;
  position: relative;
  z-index: 1;
}

.tip-item {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.7;
  padding: 18rpx 0;
}

.tip-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #8b6fe8, #7b5cf0);
  margin-top: 14rpx;
  flex-shrink: 0;
  box-shadow: 0 4rpx 8rpx rgba(123, 92, 240, 0.35);
}

.card-action .card-title {
  margin-bottom: 0;
}

.card-action {
  padding: 28rpx;
}

.card-action .section-hint {
  margin: -4rpx 0 16rpx;
}

.quick-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
}

.quick-grid-3 {
  grid-template-columns: repeat(3, 1fr);
}

.quick-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  padding: 20rpx 12rpx;
  background: linear-gradient(145deg, #ffffff 0%, #f5f0fc 100%);
  border: 2rpx solid rgba(255, 255, 255, 0.9);
  border-radius: 24rpx;
  box-shadow: var(--shadow-clay-sm);
}

.quick-btn.compact .quick-icon-wrap {
  width: 56rpx;
  height: 56rpx;
  border-radius: 18rpx;
  margin-bottom: 0;
}

.quick-btn.compact .quick-icon {
  font-size: 30rpx;
}

.quick-btn.compact .quick-label {
  font-size: 24rpx;
}

.quick-btn:active {
  box-shadow: var(--shadow-inset);
  transform: scale(0.98);
}

.quick-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  background: linear-gradient(145deg, #f0ebf8, #e4ddf0);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-inset);
}

.quick-icon {
  font-size: 38rpx;
  line-height: 1;
}

.quick-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
}

.card-header {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  margin-bottom: 16rpx;
}

.card-link-pill {
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  background: linear-gradient(135deg, #ffb86a, #ff9f5a);
  color: #fff;
  font-size: 24rpx;
  font-weight: 600;
  box-shadow: 0 8rpx 20rpx rgba(255, 159, 90, 0.38);
  flex-shrink: 0;
  margin-top: 8rpx;
}

.card-link-pill:active {
  transform: scale(0.96);
}

.timeline-item {
  display: flex;
  gap: 16rpx;
  margin-bottom: 16rpx;
}

.timeline-item:last-child {
  margin-bottom: 0;
}

.timeline-time {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  width: 72rpx;
  flex-shrink: 0;
  padding-top: 28rpx;
  font-weight: 500;
}

.timeline-bubble {
  flex: 1;
  display: flex;
  gap: 20rpx;
  align-items: center;
  padding: 24rpx 28rpx;
  background: linear-gradient(145deg, #ffffff, #f8f4ff);
  border-radius: 28rpx;
  box-shadow: var(--shadow-clay-sm);
  border: 2rpx solid rgba(255, 255, 255, 0.8);
}

.timeline-icon-wrap {
  width: 64rpx;
  height: 64rpx;
  background: linear-gradient(145deg, #f0ebf8, #e4ddf0);
  border-radius: 20rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-inset);
  flex-shrink: 0;
}

.timeline-icon {
  font-size: 36rpx;
  line-height: 1;
}

.timeline-text {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  flex: 1;
}

.timeline-title {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
}

.timeline-detail {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  line-height: 1.4;
}