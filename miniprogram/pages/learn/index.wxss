.recommend-card {
  background: linear-gradient(135deg, #8b6fe8 0%, #7b5cf0 55%, #6b4fd4 100%);
  border-radius: 44rpx;
  padding: 36rpx 32rpx 24rpx;
  margin-bottom: 28rpx;
  box-shadow: var(--shadow-clay-lg);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.recommend-head {
  margin-bottom: 24rpx;
}

.recommend-eyebrow {
  display: block;
  font-size: 20rpx;
  font-weight: 600;
  color: rgba(255, 255, 255, 0.7);
  letter-spacing: 3rpx;
  margin-bottom: 8rpx;
}

.recommend-title {
  display: block;
  font-size: 32rpx;
  font-weight: 700;
  color: #fff;
  margin-bottom: 6rpx;
}

.recommend-sub {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
}

.recommend-item {
  display: flex;
  align-items: center;
  gap: 20rpx;
  padding: 24rpx;
  margin-bottom: 12rpx;
  background: rgba(255, 255, 255, 0.15);
  border-radius: 28rpx;
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.recommend-item:last-child {
  margin-bottom: 0;
}

.recommend-item:active {
  background: rgba(255, 255, 255, 0.22);
}

.recommend-icon-wrap {
  width: 72rpx;
  height: 72rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.9);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  flex-shrink: 0;
}

.recommend-body {
  flex: 1;
  min-width: 0;
}

.recommend-item-title {
  display: block;
  font-size: 28rpx;
  font-weight: 600;
  color: #fff;
  margin-bottom: 6rpx;
}

.recommend-item-summary {
  font-size: 22rpx;
  color: rgba(255, 255, 255, 0.8);
  line-height: 1.4;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.recommend-arrow {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #ffb86a, #ff9f5a);
  color: #fff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.category-scroll {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 28rpx;
}

.category-list {
  display: inline-flex;
  gap: 12rpx;
  padding: 4rpx 0;
}

.category-chip {
  display: inline-flex;
  padding: 18rpx 32rpx;
  border-radius: 999rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  background: linear-gradient(145deg, #faf8ff, #f0ebf8);
  box-shadow: var(--shadow-clay-sm);
  border: 2rpx solid rgba(255, 255, 255, 0.7);
  flex-shrink: 0;
}

.category-chip.active {
  background: linear-gradient(135deg, #8b6fe8, #7b5cf0);
  color: #fff;
  font-weight: 600;
  box-shadow: 0 10rpx 24rpx rgba(123, 92, 240, 0.35);
}

.article-list {
  margin-bottom: 24rpx;
}

.article-card {
  display: flex;
  gap: 24rpx;
  padding: 28rpx 32rpx;
  margin-bottom: 16rpx;
  background: linear-gradient(145deg, #faf8ff, #f3eef9);
  border-radius: 32rpx;
  box-shadow: var(--shadow-clay-sm);
  border: 2rpx solid rgba(255, 255, 255, 0.65);
}

.article-card:active {
  box-shadow: var(--shadow-inset);
}

.article-icon-wrap {
  width: 80rpx;
  height: 80rpx;
  border-radius: 24rpx;
  background: linear-gradient(145deg, #f0ebf8, #e4ddf0);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: var(--shadow-inset);
}

.article-icon {
  font-size: 38rpx;
}

.article-body {
  flex: 1;
  min-width: 0;
}

.article-meta {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.article-category {
  font-size: 22rpx;
  font-weight: 600;
  color: var(--color-accent);
}

.article-time {
  font-size: 22rpx;
  color: var(--color-text-tertiary);
}

.article-title {
  display: block;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 8rpx;
  line-height: 1.4;
}

.article-summary {
  font-size: 24rpx;
  color: var(--color-text-tertiary);
  line-height: 1.5;
  display: -webkit-box;
  -webkit-box-orient: vertical;
  -webkit-line-clamp: 2;
  overflow: hidden;
}

.disclaimer-tip {
  text-align: center;
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  line-height: 1.6;
  padding: 16rpx 24rpx 32rpx;
}
