<page-header title="我的" />
<view class="container">
  <view class="profile-card">
    <view class="avatar">🌸</view>
    <view class="profile-info">
      <text class="profile-name">{{nickName}}</text>
      <text class="profile-desc">{{confinementText}}</text>
    </view>
  </view>

  <view class="stat-row">
    <view class="stat-item">
      <text class="stat-num">{{recordCount}}</text>
      <text class="stat-label">恢复记录</text>
    </view>
  </view>

  <view class="menu-card">
    <view class="menu-item" bindtap="goSettings">
      <view class="menu-icon">⚙️</view>
      <text class="menu-text">个人档案 / 月子设置</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goDisclaimer">
      <view class="menu-icon">📋</view>
      <text class="menu-text">免责声明</text>
      <text class="menu-arrow">›</text>
    </view>
    <view class="menu-item" bindtap="goPrivacy">
      <view class="menu-icon">🔒</view>
      <text class="menu-text">隐私政策</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="menu-card danger">
    <view class="menu-item" bindtap="onClearData">
      <view class="menu-icon">🗑️</view>
      <text class="menu-text danger-text">清除所有数据</text>
      <text class="menu-arrow">›</text>
    </view>
  </view>

  <view class="footer-tip">沐沐记 v1.0 · 内容仅供参考，不能替代医疗建议</view>
</view>
