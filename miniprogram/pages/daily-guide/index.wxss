.stage-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 12rpx;
  margin-bottom: 24rpx;
}

.stage-chip {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  padding: 20rpx 12rpx;
  border-radius: 24rpx;
  background: linear-gradient(145deg, #faf8ff, #f0ebf8);
  box-shadow: var(--shadow-clay-sm);
  border: 2rpx solid rgba(255, 255, 255, 0.7);
}

.stage-chip.active {
  background: linear-gradient(135deg, #8b6fe8, #7b5cf0);
  box-shadow: 0 10rpx 24rpx rgba(123, 92, 240, 0.35);
}

.stage-chip-label {
  font-size: 24rpx;
  font-weight: 700;
  color: var(--color-text);
}

.stage-chip.active .stage-chip-label,
.stage-chip.active .stage-chip-range {
  color: #fff;
}

.stage-chip-range {
  font-size: 20rpx;
  color: var(--color-text-tertiary);
  text-align: center;
  line-height: 1.3;
}

.guide-card {
  background: linear-gradient(135deg, #8b6fe8 0%, #7b5cf0 55%, #6b4fd4 100%);
  border-radius: 40rpx;
  padding: 36rpx 32rpx;
  margin-bottom: 20rpx;
  box-shadow: var(--shadow-clay-lg);
  border: 2rpx solid rgba(255, 255, 255, 0.2);
}

.guide-badge {
  display: inline-block;
  font-size: 22rpx;
  font-weight: 600;
  color: #7b5cf0;
  background: rgba(255, 255, 255, 0.92);
  padding: 8rpx 20rpx;
  border-radius: 999rpx;
  margin-bottom: 20rpx;
}

.guide-focus {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.4;
  margin-bottom: 12rpx;
}

.guide-range {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.8);
}

.section-card {
  background: linear-gradient(145deg, #faf8ff, #f3eef9);
  border-radius: 32rpx;
  padding: 32rpx;
  margin-bottom: 16rpx;
  box-shadow: var(--shadow-clay-sm);
  border: 2rpx solid rgba(255, 255, 255, 0.65);
}

.section-watch {
  border-color: rgba(255, 159, 90, 0.25);
}

.section-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: var(--color-text);
  margin-bottom: 24rpx;
}

.guide-item {
  display: flex;
  gap: 16rpx;
  margin-bottom: 20rpx;
}

.guide-item:last-child {
  margin-bottom: 0;
}

.guide-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  margin-top: 14rpx;
  flex-shrink: 0;
}

.guide-dot.care {
  background: #6b8f71;
}

.guide-dot.avoid {
  background: #ff9f5a;
}

.guide-dot.watch {
  background: #e8879a;
}

.guide-text {
  flex: 1;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  line-height: 1.75;
}

.disclaimer-tip {
  text-align: center;
  font-size: 22rpx;
  color: var(--color-text-tertiary);
  line-height: 1.6;
  padding: 24rpx 16rpx 48rpx;
}
