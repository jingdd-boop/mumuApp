.page-header {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 200;
  background: transparent;
  box-sizing: border-box;
}

.nav-bar {
  display: flex;
  align-items: center;
  padding: 0 36rpx;
  box-sizing: border-box;
}

.back-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 80rpx;
  height: 80rpx;
  margin-right: 12rpx;
  margin-left: -8rpx;
  flex-shrink: 0;
  border-radius: 24rpx;
  background: linear-gradient(145deg, #faf8ff, #f0ebf8);
  box-shadow: var(--shadow-clay-sm);
  border: 2rpx solid rgba(255, 255, 255, 0.7);
}

.back-btn:active {
  box-shadow: var(--shadow-inset);
}

.back-icon {
  font-size: 44rpx;
  font-weight: 400;
  color: var(--color-text);
  line-height: 1;
  margin-top: -4rpx;
}

.title-wrap {
  display: flex;
  flex-direction: column;
  justify-content: center;
  flex: 1;
  min-width: 0;
  padding-right: 180rpx;
}

.nav-title {
  font-size: 52rpx;
  font-weight: 700;
  color: var(--color-text);
  line-height: 1.2;
  letter-spacing: -1rpx;
}

.nav-subtitle {
  font-size: 28rpx;
  color: var(--color-text-secondary);
  margin-top: 8rpx;
  line-height: 1.4;
  font-weight: 400;
}

.header-placeholder {
  width: 100%;
  flex-shrink: 0;
}
