# 服务端口
PORT=3000

# 运行环境: development | production
NODE_ENV=development

# JWT 签名密钥（生产环境务必修改）
JWT_SECRET=your-random-secret

# 微信小程序（开发环境可留空，将使用固定 mock openid）
WECHAT_APP_ID=
WECHAT_APP_SECRET=
# 开发环境 mock 用户 openid（未配置微信 AppId 时生效，保持固定以便刷新不丢数据）
DEV_OPENID=dev_local_user

# MySQL 数据库
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=tinydays
DB_PASSWORD=your_password
DB_NAME=tinydays
